---
import { fetchContacts, fetchSettings } from '../lib/sanity.js';
const { contacts } = await fetchContacts();
const { site, social } = await fetchSettings();
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-lg flex-shrink-0">
            <img src="/images/logo.png" alt="Wairau Rowing Club" class="w-14 h-14 object-contain" />
          </div>
          <div class="font-display font-extrabold text-2xl leading-tight">
            WAIRAU<br /><span class="text-teal">ROWING CLUB</span>
          </div>
        </div>
        <p class="text-white/60 text-sm max-w-md leading-relaxed">
          {site.description}
        </p>
        <div class="flex gap-3 mt-6">
          {social.facebookUrl ? (
            <a href={social.facebookUrl} target="_blank" rel="noopener" aria-label="Facebook" class="w-10 h-10 rounded-full bg-white/10 hover:bg-teal/20 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          ) : (
            <span aria-label="Facebook link coming soon" title="Facebook link coming soon" class="w-10 h-10 rounded-full bg-white/5 text-white/30 flex items-center justify-center cursor-not-allowed">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </span>
          )}
          {social.instagramUrl ? (
            <a href={social.instagramUrl} target="_blank" rel="noopener" aria-label="Instagram" class="w-10 h-10 rounded-full bg-white/10 hover:bg-teal/20 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          ) : null}
        </div>
      </div>

      <div>
        <h3 class="font-display font-bold text-xs uppercase tracking-[0.18em] text-teal mb-4">Quick Links</h3>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li><a href="/programs" class="hover:text-white transition-colors">Programs</a></li>
          <li><a href="/regattas" class="hover:text-white transition-colors">Regattas</a></li>
          <li><a href="/membership" class="hover:text-white transition-colors">Become a Member</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">Our Story</a></li>
          <li><a href="/about#alumni" class="hover:text-white transition-colors">Alumni</a></li>
          <li><a href="/committee" class="hover:text-white transition-colors">Our People</a></li>
          <li><a href="/news" class="hover:text-white transition-colors">News</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display font-bold text-xs uppercase tracking-[0.18em] text-teal mb-4">Contact</h3>
        <div class="space-y-3 text-sm text-white/60">
          <p>Wairau River, Marlborough<br />New Zealand</p>
          {contacts.filter((c) => !c.tbc).map((c) => (
            <div>
              <div class="text-white text-sm font-semibold">{c.name}</div>
              <div class="text-xs text-white/50">{c.role}</div>
              {c.email && (
                <a href={`mailto:${c.email}`} class="block hover:text-teal transition-colors text-xs mt-1 break-all">{c.email}</a>
              )}
              {c.phone && (
                <a href={`tel:${c.phone.replace(/\s/g, '')}`} class="block hover:text-teal transition-colors text-xs">{c.phone}</a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/40">
      <p>© {year} {site.name}. Founded {site.founded}.</p>
      <p>Made with ♥ in Marlborough.</p>
    </div>

    <!-- Designer credit -->
    <div class="mt-4 pt-4 border-t border-white/5 flex justify-center">
      <a
        href="https://blackcircle.nz"
        target="_blank"
        rel="noopener"
        class="group inline-flex items-center gap-2 text-xs text-white/40 hover:text-white transition-colors"
      >
        <span class="tracking-wide">Designed &amp; built by</span>
        <span class="inline-flex items-center gap-1.5 font-semibold">
          <span class="w-2 h-2 rounded-full bg-white/50 group-hover:bg-white transition-colors"></span>
          <span class="group-hover:underline underline-offset-4 decoration-from-font">blackcircle.nz</span>
        </span>
      </a>
    </div>
  </div>
</footer>
