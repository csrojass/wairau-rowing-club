---
import { navLinks, site } from '../data/site.js';
const path = Astro.url.pathname;
const isActive = (href) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<nav class="bg-navy text-white sticky top-0 z-50 shadow-lg backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24">
      <a href="/" class="flex items-center gap-4 group">
        <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-white flex items-center justify-center shadow-lg ring-2 ring-white/0 group-hover:ring-teal transition">
          <img src="/images/logo.png" alt="Wairau Rowing Club" class="w-14 h-14 lg:w-[68px] lg:h-[68px] object-contain" />
        </div>
        <div class="leading-tight">
          <div class="font-display font-bold text-lg sm:text-xl tracking-wide">Wairau</div>
          <div class="font-display font-medium text-xs sm:text-sm text-teal tracking-[0.18em] italic">Rowing Club</div>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              isActive(link.href) ? 'text-teal' : 'text-white/80 hover:text-white hover:bg-white/5'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/membership"
          class="ml-3 bg-coral hover:bg-coral-600 text-white px-5 py-2.5 rounded-lg text-sm font-bold transition-colors shadow-md"
        >
          Join Now
        </a>
      </div>

      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        class="lg:hidden text-white p-2 rounded-md hover:bg-white/10 transition-colors"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="space-y-1 pt-2 border-t border-white/10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`block px-3 py-2.5 rounded-md text-sm font-medium ${
              isActive(link.href) ? 'text-teal bg-white/5' : 'text-white/80 hover:text-white hover:bg-white/5'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/membership"
          class="block mt-3 bg-coral hover:bg-coral-600 text-white text-center px-4 py-3 rounded-lg font-bold"
        >
          Join Now
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const open = document.getElementById('icon-open');
  const close = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    open?.classList.toggle('hidden');
    close?.classList.toggle('hidden');
  });
</script>
