---
// All icons are rowing-themed line drawings. Prop names are kept stable
// (boat / cap / people / peak / wave / tree / flow / circle) so existing
// references throughout the site continue to work — only the visuals change.
//
// boat   → scull (small boat, one rower)
// cap    → eight (long racing shell, multiple rowers)
// people → crew (rowers seated together)
// peak   → medal (rowing medal with ribbon)
// wave   → waves on the water (unchanged)
// tree   → crossed oars (classic heraldic rowing emblem)
// flow   → single oar (rowing stroke arc)
// circle → boathouse with reflection

interface Props {
  name: 'boat' | 'cap' | 'people' | 'peak' | 'wave' | 'tree' | 'flow' | 'circle';
  class?: string;
}
const { name, class: className = 'w-8 h-8' } = Astro.props;
const common = {
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.5',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  viewBox: '0 0 48 48',
  class: className,
};
---

{/* boat → SCULL (small boat with one rower + sculling oars) */}
{name === 'boat' && (
  <svg {...common}>
    <path d="M6 28 Q 24 33 42 28" stroke-width="2" />
    <circle cx="24" cy="24" r="2.2" fill="currentColor" />
    <path d="M22 22 L 11 16" />
    <path d="M26 22 L 37 16" />
    <ellipse cx="9" cy="15" rx="2.6" ry="1.4" transform="rotate(-25 9 15)" />
    <ellipse cx="39" cy="15" rx="2.6" ry="1.4" transform="rotate(25 39 15)" />
    <path d="M6 38 Q 16 34 24 38 T 42 38" />
  </svg>
)}

{/* cap → EIGHT (long racing shell with 5 rowers + oars at the catch) */}
{name === 'cap' && (
  <svg {...common}>
    <path d="M3 28 Q 24 33 45 28" stroke-width="2" />
    <g fill="currentColor">
      <circle cx="11" cy="25" r="1.4" />
      <circle cx="18" cy="25" r="1.4" />
      <circle cx="25" cy="25" r="1.4" />
      <circle cx="32" cy="25" r="1.4" />
      <circle cx="39" cy="25" r="1.4" />
    </g>
    <path d="M11 24 L 7 17" />
    <path d="M18 24 L 14 17" />
    <path d="M25 24 L 21 17" />
    <path d="M32 24 L 28 17" />
    <path d="M39 24 L 35 17" />
    <path d="M3 38 Q 14 34 24 38 T 45 38" />
  </svg>
)}

{/* people → COXED PAIR / DOUBLE (two rowers side-on, oars extending) */}
{name === 'people' && (
  <svg {...common}>
    <path d="M6 30 Q 24 35 42 30" stroke-width="2" />
    <circle cx="18" cy="25" r="2.4" fill="currentColor" />
    <circle cx="30" cy="25" r="2.4" fill="currentColor" />
    <path d="M16 24 L 4 18" />
    <path d="M32 24 L 44 18" />
    <ellipse cx="3" cy="17" rx="2.6" ry="1.4" transform="rotate(-25 3 17)" />
    <ellipse cx="45" cy="17" rx="2.6" ry="1.4" transform="rotate(25 45 17)" />
    <path d="M6 40 Q 16 36 24 40 T 42 40" />
  </svg>
)}

{/* peak → MEDAL (rowing medal with ribbon + mini crossed oars inside) */}
{name === 'peak' && (
  <svg {...common}>
    <path d="M14 4 L 20 18" />
    <path d="M34 4 L 28 18" />
    <circle cx="24" cy="30" r="10" stroke-width="1.8" />
    <line x1="20" y1="34" x2="28" y2="26" />
    <line x1="28" y1="34" x2="20" y2="26" />
    <circle cx="18" cy="36" r="1" fill="currentColor" />
    <circle cx="30" cy="36" r="1" fill="currentColor" />
  </svg>
)}

{/* wave → WAVES on the water */}
{name === 'wave' && (
  <svg {...common}>
    <path d="M4 18 Q 12 12 20 18 T 36 18 T 44 18" />
    <path d="M4 28 Q 12 22 20 28 T 36 28 T 44 28" />
    <path d="M4 38 Q 12 32 20 38 T 36 38 T 44 38" />
  </svg>
)}

{/* tree → CROSSED OARS (classic rowing heraldic emblem) */}
{name === 'tree' && (
  <svg {...common}>
    <line x1="8" y1="40" x2="38" y2="10" stroke-width="2" />
    <line x1="40" y1="40" x2="10" y2="10" stroke-width="2" />
    <ellipse cx="40" cy="8" rx="3" ry="4.5" transform="rotate(45 40 8)" fill="currentColor" />
    <ellipse cx="8" cy="8" rx="3" ry="4.5" transform="rotate(-45 8 8)" fill="currentColor" />
    <rect x="6.5" y="40" width="3" height="2.5" rx="0.6" transform="rotate(-45 8 41)" />
    <rect x="38.5" y="40" width="3" height="2.5" rx="0.6" transform="rotate(45 40 41)" />
  </svg>
)}

{/* flow → SINGLE OAR (one oar pulled through the stroke, with water arc) */}
{name === 'flow' && (
  <svg {...common}>
    <line x1="10" y1="36" x2="34" y2="12" stroke-width="2" />
    <ellipse cx="36" cy="10" rx="4" ry="6" transform="rotate(45 36 10)" fill="currentColor" />
    <rect x="6.5" y="36" width="4" height="2.5" rx="0.8" transform="rotate(-45 8 37)" />
    <path d="M6 42 Q 18 38 30 42" opacity="0.6" />
  </svg>
)}

{/* circle → BOATHOUSE on the riverbank with reflection */}
{name === 'circle' && (
  <svg {...common}>
    <path d="M10 24 L 24 12 L 38 24" />
    <path d="M14 22 V 34 H 34 V 22" />
    <line x1="22" y1="34" x2="22" y2="26" />
    <line x1="26" y1="34" x2="26" y2="26" />
    <line x1="22" y1="26" x2="26" y2="26" />
    <path d="M4 38 Q 12 34 20 38 T 36 38 T 44 38" />
    <path d="M4 42 Q 12 40 20 42 T 36 42 T 44 42" opacity="0.5" />
  </svg>
)}
