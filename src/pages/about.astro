---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { fetchContacts, fetchSettings } from '../lib/sanity.js';

const { contacts } = await fetchContacts();
const { rowingConnect, social, heritage } = await fetchSettings();
const secretary = contacts.find((c) => c.role === 'Secretary');
---

<Layout
  title="Our Story"
  description="Founded 27 July 1910 in Grovetown. The fourth Wairau Rowing Club boathouse sits on 11 km of pristine training water in Marlborough. Once a Wairau rower… always a Wairau rower."
>
  <PageHero
    eyebrow="Since 1910"
    title="Our story."
    subtitle="More than a century of rowing, on one of New Zealand's finest stretches of flat water."
  />

  <!-- HISTORY -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="reveal text-coral font-bold text-xs uppercase tracking-[0.18em] mb-3">History</div>
      <h2 class="reveal font-display text-3xl sm:text-4xl text-navy leading-tight mb-8">A club founded by 30 people in a Grovetown hall.</h2>

      <div class="reveal prose prose-slate prose-lg max-w-none space-y-5 text-slate-700 leading-relaxed">
        <p>
          The Wairau Rowing Club was established on the <strong>27th of July 1910</strong>, following a general meeting held in the Grovetown Hall attended by approximately 30 people. A committee meeting on the <strong>31st July 1910</strong> chose the site for the first boat shed — on the Wairau River, 15 yards north of the old culvert. The secretary was instructed to write to the Spring Creek River Board for permission to erect it.
        </p>
        <p>
          That site is still the home of the club today — at the end of <strong>Steam Wharf Road, Grovetown</strong>, 5&nbsp;km north-east of Blenheim.
        </p>
      </div>

      <div class="reveal mt-12 bg-cream rounded-2xl p-8">
        <div class="text-coral font-bold text-xs uppercase tracking-[0.18em] mb-2">The fourth clubhouse</div>
        <h3 class="font-display text-2xl text-navy mb-4">Built in 2005.</h3>
        <div class="space-y-4 text-slate-700 leading-relaxed">
          <p>
            The current clubhouse — built in 2005 — is the fourth in the club's history. The first two were lost to flooding over the years, forcing a move onto reclaimed land for the third, level with the protection stop bank.
          </p>
          <p>
            The new building replaced an old iron-clad shed with limited facilities. It comprises a large boatshed area and basement, changing rooms, an upstairs lounge with balcony, committee room and kitchen — an attractive permanent facility built to last.
          </p>
          <p>
            From the boathouse it's an easy 75-metre lawn walk down to the Wairau River and the sheltered long-distance training water it offers.
          </p>
        </div>
      </div>

      <div class="reveal mt-12">
        <p class="text-slate-700 text-lg leading-relaxed">
          The club is within easy cycling distance of Blenheim and serves as the home of rowing in Marlborough — including the <strong>Marlborough Girls' College</strong> and <strong>Marlborough Boys' College</strong> rowing programmes. Both colleges row in club colours at club regattas, and in their own school colours at the South Island Secondary Schools and National Championship regattas.
        </p>
      </div>
    </div>
  </section>

  <!-- THE RIVER -->
  <section class="bg-cream py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="reveal text-coral font-bold text-xs uppercase tracking-[0.18em] mb-3">The river</div>
      <h2 class="reveal font-display text-3xl sm:text-4xl text-navy leading-tight mb-8">
        170 km long. <span class="font-script text-ocean text-2xl sm:text-3xl">11 km perfect for rowing.</span>
      </h2>
      <div class="reveal space-y-5 text-slate-700 text-lg leading-relaxed">
        <p>
          At 170&nbsp;km, the Wairau is one of the longer rivers in the South Island. From the Spenser Mountains the river meanders down the Wairau Valley as a braided river — until it reaches Spring Creek, where it transforms into 11&nbsp;km of calm, flat water making its way to the sea.
        </p>
        <p>That stretch is our training ground — and one of the best rowing waters in New Zealand.</p>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl text-navy text-center mb-12">
        What we stand for.
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal bg-white rounded-3xl p-8">
          <div class="w-14 h-14 bg-ocean/10 text-ocean rounded-full flex items-center justify-center mb-6">
            <Icon name="circle" class="w-7 h-7" />
          </div>
          <h3 class="font-display font-bold text-2xl text-navy mb-3">Community</h3>
          <p class="text-slate-600 leading-relaxed">A welcoming home for rowers of every age and ability — from school squads to masters.</p>
        </div>
        <div class="reveal delay-1 bg-white rounded-3xl p-8">
          <div class="w-14 h-14 bg-ocean/10 text-ocean rounded-full flex items-center justify-center mb-6">
            <Icon name="flow" class="w-7 h-7" />
          </div>
          <h3 class="font-display font-bold text-2xl text-navy mb-3">Performance</h3>
          <p class="text-slate-600 leading-relaxed">A pathway from learn-to-row through to the New Zealand high-performance squad.</p>
        </div>
        <div class="reveal delay-2 bg-white rounded-3xl p-8">
          <div class="w-14 h-14 bg-ocean/10 text-ocean rounded-full flex items-center justify-center mb-6">
            <Icon name="tree" class="w-7 h-7" />
          </div>
          <h3 class="font-display font-bold text-2xl text-navy mb-3">Heritage</h3>
          <p class="text-slate-600 leading-relaxed">115 years of stories, traditions and rowing memories — and we're still being written.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HERITAGE / FIRST MINUTES PDF -->
  <section class="bg-cream py-16 lg:py-20 px-4 sm:px-6 lg:px-8">
    <div class="reveal max-w-5xl mx-auto bg-white border border-slate-200 rounded-3xl p-8 sm:p-10 grid md:grid-cols-5 gap-8 lg:gap-12 items-center">
      <div class="md:col-span-2">
        {heritage.firstMinutesPdf ? (
          <a href={heritage.firstMinutesPdf} target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-shadow border border-slate-100">
            <img
              src="/images/first-minutes-1910-page1.jpg"
              alt="First page of the original Wairau Rowing Club committee minutes, 31 July 1910"
              class="w-full h-auto group-hover:scale-[1.01] transition-transform duration-700"
              loading="lazy"
            />
          </a>
        ) : (
          <div class="aspect-[3/4] rounded-2xl bg-slate-100 flex items-center justify-center text-slate-400 text-xs">
            Snapshot coming soon
          </div>
        )}
      </div>
      <div class="md:col-span-3">
        <div class="text-coral font-bold text-xs uppercase tracking-[0.18em] mb-3">From the archives</div>
        <h3 class="font-display text-2xl sm:text-3xl text-navy mb-4">The 1910 first minutes.</h3>
        <p class="text-slate-600 leading-relaxed mb-6">
          Read the original committee minutes from <strong>31 July 1910</strong> — the day a site was chosen for the first boat shed at Grovetown, 15 yards north of the old culvert.
        </p>
        {heritage.firstMinutesPdf ? (
          <a href={heritage.firstMinutesPdf} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-navy hover:bg-ocean text-white font-bold px-6 py-3 rounded-full text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Open the full PDF
          </a>
        ) : (
          <div class="inline-flex items-center gap-2 bg-slate-100 text-slate-500 font-semibold px-6 py-3 rounded-full text-sm">
            PDF coming soon
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ALUMNI INTRO -->
  <section id="alumni" class="py-20 lg:py-24 px-4 sm:px-6 lg:px-8 scroll-mt-24">
    <div class="reveal max-w-3xl mx-auto text-center">
      <div class="text-coral font-bold text-xs uppercase tracking-[0.18em] mb-4">Alumni</div>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-navy leading-tight mb-2">
        Once a Wairau rower…
      </h2>
      <h2 class="font-script text-3xl sm:text-4xl lg:text-5xl text-ocean leading-tight mb-10">
        …always a Wairau rower.
      </h2>
      <p class="font-display text-xl sm:text-2xl text-navy leading-snug mb-8">
        Are you a past member of the Wairau Rowing Club?
      </p>
      <div class="space-y-5 text-lg text-slate-700 leading-relaxed">
        <p>Since 1910, the Wairau Rowing Club has provided a sporting and social home for rowing on the Wairau River.</p>
        <p>All of us have, in our own way, contributed to the vibrancy, growth, longevity, sporting success and community of our club.</p>
        <p class="text-navy font-medium">We’d love to have you aboard again.</p>
      </div>
    </div>
  </section>

  <!-- THREE WAYS BACK -->
  <section class="bg-cream py-16 lg:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="reveal text-center mb-12">
        <div class="text-coral font-bold text-xs uppercase tracking-[0.18em] mb-3">Reconnect</div>
        <h2 class="font-display text-3xl sm:text-4xl text-navy">Three ways back.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- 1. Rowing Connect -->
        <div class="reveal bg-white rounded-3xl p-7 flex flex-col">
          <div class="w-14 h-14 rounded-full bg-ocean/10 text-ocean flex items-center justify-center mb-5">
            <Icon name="boat" class="w-7 h-7" />
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-coral mb-2">01</div>
          <h3 class="font-display text-2xl text-navy mb-3">Register on Rowing Connect</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-5 flex-grow">
            Rowing NZ’s free national platform. Register as a supporter, previous member or volunteer — it costs nothing and keeps you in the loop.
          </p>
          {rowingConnect.url ? (
            <a href={rowingConnect.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-coral hover:bg-coral-600 text-white font-bold px-5 py-2.5 rounded-full text-sm transition-colors">
              Register on Rowing Connect
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          ) : (
            <div>
              <div class="inline-flex items-center gap-2 bg-slate-200 text-slate-500 font-semibold px-5 py-2.5 rounded-full text-sm">
                Link coming soon
              </div>
              <p class="text-xs text-slate-400 mt-3">
                In the meantime — <a href={rowingConnect.generalInfoUrl} target="_blank" rel="noopener" class="text-ocean hover:text-coral underline">learn about Rowing Connect</a>.
              </p>
            </div>
          )}
        </div>

        <!-- 2. Facebook -->
        <div class="reveal delay-1 bg-white rounded-3xl p-7 flex flex-col">
          <div class="w-14 h-14 rounded-full bg-ocean/10 text-ocean flex items-center justify-center mb-5">
            <Icon name="circle" class="w-7 h-7" />
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-coral mb-2">02</div>
          <h3 class="font-display text-2xl text-navy mb-3">Follow on Facebook</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-5 flex-grow">
            See what the current crews are up to, regatta results, and club photos. The fastest way back into the conversation.
          </p>
          {social.facebookUrl ? (
            <a href={social.facebookUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-navy hover:bg-ocean text-white font-bold px-5 py-2.5 rounded-full text-sm transition-colors">
              Find us on Facebook
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          ) : (
            <div class="inline-flex items-center gap-2 bg-slate-200 text-slate-500 font-semibold px-5 py-2.5 rounded-full text-sm">
              Link coming soon
            </div>
          )}
        </div>

        <!-- 3. Email -->
        <div class="reveal delay-2 bg-white rounded-3xl p-7 flex flex-col">
          <div class="w-14 h-14 rounded-full bg-ocean/10 text-ocean flex items-center justify-center mb-5">
            <Icon name="flow" class="w-7 h-7" />
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-coral mb-2">03</div>
          <h3 class="font-display text-2xl text-navy mb-3">Drop us a line</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-5 flex-grow">
            Got photos, stories, or memorabilia? Want to organise a reunion crew? Email our secretary {secretary?.name}.
          </p>
          {secretary?.email && (
            <a href={`mailto:${secretary.email}`} class="inline-flex items-center gap-2 bg-white border-2 border-navy hover:bg-navy hover:text-white text-navy font-bold px-5 py-2.5 rounded-full text-sm transition-colors break-all">
              {secretary.email}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="reveal max-w-3xl mx-auto text-center">
      <div class="font-script text-3xl sm:text-4xl text-ocean leading-snug">
        We’d love to have you aboard again.
      </div>
    </div>
  </section>
</Layout>
