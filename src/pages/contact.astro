---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { fetchContacts } from '../lib/sanity.js';

const { contacts } = await fetchContacts();
---

<Layout
  title="Contact"
  description="Get in touch with the Wairau Rowing Club at Steam Wharf Road, Grovetown, Blenheim."
>
  <PageHero
    eyebrow="Get in touch"
    title="Talk to us."
    subtitle="Drop us a line — we'll respond within a couple of days."
  />

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2 space-y-6">
        {contacts.map((c) => (
          <div class={`bg-white border rounded-2xl p-6 ${c.tbc ? 'border-dashed border-slate-300' : 'border-slate-200'}`}>
            <div class="text-xs font-bold uppercase tracking-wider text-coral mb-1">{c.role}</div>
            <h3 class={`font-display font-bold text-xl mb-4 ${c.tbc ? 'text-slate-400 italic' : 'text-navy'}`}>{c.tbc ? 'To be confirmed' : c.name}</h3>
            <div class="space-y-3">
              {c.tbc && (
                <p class="text-xs text-slate-500">Position currently vacant. In the meantime, reach out to our Club Captain or Secretary.</p>
              )}
              {c.phone && (
                <a href={`tel:${c.phone.replace(/\s/g, '')}`} class="flex items-center gap-3 text-slate-700 hover:text-ocean transition-colors group">
                  <div class="w-9 h-9 rounded-lg bg-teal/10 group-hover:bg-teal group-hover:text-white text-teal flex items-center justify-center transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <span class="text-sm font-medium">{c.phone}</span>
                </a>
              )}
              {c.email && (
                <a href={`mailto:${c.email}`} class="flex items-center gap-3 text-slate-700 hover:text-ocean transition-colors group">
                  <div class="w-9 h-9 rounded-lg bg-teal/10 group-hover:bg-teal group-hover:text-white text-teal flex items-center justify-center transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <span class="text-sm font-medium break-all">{c.email}</span>
                </a>
              )}
            </div>
          </div>
        ))}

        <div class="bg-navy text-white rounded-2xl p-6">
          <div class="text-xs font-bold uppercase tracking-wider text-teal mb-2">Boathouse</div>
          <h3 class="font-display font-bold text-xl mb-3">Where to find us</h3>
          <p class="text-white/70 text-sm leading-relaxed">
            On the banks of the Wairau River, Marlborough.<br />
            South Island, New Zealand.
          </p>
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
          <h2 class="font-display font-extrabold text-2xl text-navy mb-2">Send a message</h2>
          <p class="text-slate-600 text-sm mb-7">We'll route it to the right person.</p>

          <form action="https://wrc-forms.csrojas.workers.dev/forms/contact" method="POST" class="space-y-5">
            <input type="text" name="_hp" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-semibold text-navy mb-1.5">Name *</label>
                <input id="name" name="name" type="text" required class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-navy mb-1.5">Email *</label>
                <input id="email" name="email" type="email" required class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-semibold text-navy mb-1.5">Subject</label>
              <input id="subject" name="subject" type="text" class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal" />
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-navy mb-1.5">Message *</label>
              <textarea id="message" name="message" rows="6" required class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal"></textarea>
            </div>
            <button type="submit" class="bg-coral hover:bg-coral-600 text-white font-bold px-8 py-4 rounded-xl transition-colors shadow-lg">
              Send message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
