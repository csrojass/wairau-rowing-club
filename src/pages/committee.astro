---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { fetchCommittee } from '../lib/sanity.js';

const { members: committee } = await fetchCommittee();

// Group by role category so the page reads cleanly with 15+ entries.
const isCollegeDelegate = (m) => /College Delegate/i.test(m.role);
const exec = committee.filter((m) => m.role !== 'Committee' && !isCollegeDelegate(m));
const members = committee.filter((m) => m.role === 'Committee');
const delegates = committee.filter(isCollegeDelegate);

const initials = (name) =>
  name === 'TBC' ? '?' : name.split(' ').map((n) => n[0]).slice(0, 2).join('');
---

<Layout title="Our People">
  <PageHero
    eyebrow="Our people"
    title="The people behind the club."
    subtitle="A volunteer committee that keeps the boats on the water and the club thriving."
  />

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display font-extrabold text-2xl sm:text-3xl text-navy mb-2">Executive</h2>
      <div class="h-1 w-12 bg-coral rounded-full mb-10"></div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-20">
        {exec.map((m) => (
          <div class={`bg-white border rounded-2xl p-6 flex items-center gap-4 hover:shadow-md transition-all ${m.tbc ? 'border-dashed border-slate-300' : 'border-slate-200 hover:border-teal'}`}>
            <div class={`w-14 h-14 rounded-full text-white font-display font-bold text-lg flex items-center justify-center shadow-md ${m.tbc ? 'bg-slate-300' : 'bg-gradient-to-br from-navy to-ocean'}`}>
              {initials(m.name)}
            </div>
            <div>
              <div class="text-xs font-bold uppercase tracking-wider text-coral mb-0.5">{m.role}</div>
              <div class={`font-display font-bold ${m.tbc ? 'text-slate-400 italic' : 'text-navy'}`}>{m.tbc ? 'To be confirmed' : m.name}</div>
            </div>
          </div>
        ))}
      </div>

      <h2 class="font-display font-extrabold text-2xl sm:text-3xl text-navy mb-2">Committee Members</h2>
      <div class="h-1 w-12 bg-coral rounded-full mb-10"></div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-20">
        {members.map((m) => (
          <div class="bg-slate-50 rounded-xl p-5 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-teal/15 text-ocean font-bold text-sm flex items-center justify-center">
              {initials(m.name)}
            </div>
            <div class="font-semibold text-navy text-sm">{m.name}</div>
          </div>
        ))}
      </div>

      {delegates.length > 0 && (
        <>
          <h2 class="font-display font-extrabold text-2xl sm:text-3xl text-navy mb-2">College Delegates</h2>
          <div class="h-1 w-12 bg-coral rounded-full mb-10"></div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {delegates.map((m) => (
              <div class="bg-white border border-slate-200 rounded-2xl p-6 flex items-center gap-4 hover:shadow-md hover:border-teal transition-all">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-ocean to-teal text-white font-display font-bold text-lg flex items-center justify-center shadow-md">
                  {initials(m.name)}
                </div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-wider text-coral mb-0.5">{m.role}</div>
                  <div class="font-display font-bold text-navy">{m.name}</div>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</Layout>
