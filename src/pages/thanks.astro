---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Thanks"
  description="Thanks — we've received your message and will be in touch soon."
  noindex={true}
>
  <PageHero
    eyebrow="Got it"
    title="Thanks — we'll be in touch."
  />

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-lg text-slate-600 leading-relaxed mb-8">
        Your message has reached us. A committee member will get back to you within a couple of days.
      </p>
      <p class="font-script text-2xl text-ocean">See you on the water.</p>

      <div class="mt-12">
        <a href="/" class="inline-flex items-center gap-2 text-ocean font-bold hover:text-coral transition-colors">
          ← Back to the home page
        </a>
      </div>
    </div>
  </section>
</Layout>
